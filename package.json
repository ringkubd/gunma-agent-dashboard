      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./styles.css": "./styles.css"
  },
  "dependencies": {
    "axios": "^1.6.7",
    "laravel-echo": "^1.15.3",
    "pusher-js": "^8.4.0",
    "lucide-react": "^0.330.0"
  },
  "peerDependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.3"
  }
}
