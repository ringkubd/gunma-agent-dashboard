{
  "name": "gunma-agent-dashboard",
  "version": "1.0.7",
  "description": "Admin monitoring and control dashboard for Gunma AI Agent",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "files": [
    "dist",
    "styles.css"
  ],
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w"
  },
  "exports": {
    ".": {
